FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --legacy-peer-deps

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

ARG NEXT_PUBLIC_BACKEND_API_URL
ARG NEXT_PUBLIC_MONAD_CHAIN_ID
ARG NEXT_PUBLIC_MONAD_NFT_CONTRACT
ARG NEXT_PUBLIC_MONAD_REWARD_CONTRACT
ARG NEXT_PUBLIC_MONAD_CCOP_CONTRACT
ARG NEXT_PUBLIC_LOCAL_NFT_CONTRACT
ARG NEXT_PUBLIC_LOCAL_REWARD_CONTRACT
ARG NEXT_PUBLIC_LOCAL_CCOP_CONTRACT

ENV NEXT_PUBLIC_BACKEND_API_URL=$NEXT_PUBLIC_BACKEND_API_URL \
    NEXT_PUBLIC_MONAD_CHAIN_ID=$NEXT_PUBLIC_MONAD_CHAIN_ID \
    NEXT_PUBLIC_MONAD_NFT_CONTRACT=$NEXT_PUBLIC_MONAD_NFT_CONTRACT \
    NEXT_PUBLIC_MONAD_REWARD_CONTRACT=$NEXT_PUBLIC_MONAD_REWARD_CONTRACT \
    NEXT_PUBLIC_MONAD_CCOP_CONTRACT=$NEXT_PUBLIC_MONAD_CCOP_CONTRACT \
    NEXT_PUBLIC_LOCAL_NFT_CONTRACT=$NEXT_PUBLIC_LOCAL_NFT_CONTRACT \
    NEXT_PUBLIC_LOCAL_REWARD_CONTRACT=$NEXT_PUBLIC_LOCAL_REWARD_CONTRACT \
    NEXT_PUBLIC_LOCAL_CCOP_CONTRACT=$NEXT_PUBLIC_LOCAL_CCOP_CONTRACT

RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000
CMD ["node", "server.js"]
