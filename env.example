# Copy this file to .env and fill in the values.
# docker-compose reads .env automatically from this directory.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=trustlayer
POSTGRES_PASSWORD=trustlayer
POSTGRES_DB=trustlayer
# Used by the backend container; keep in sync with the values above.
DATABASE_URL=postgresql://trustlayer:trustlayer@postgres:5432/trustlayer

# ── Contracts / Hardhat ───────────────────────────────────────────────────────
# Wallet private key (without 0x prefix) used for deploying contracts.
PRIVATE_KEY=
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC=https://rpc.monad.xyz
# API key for contract verification on Monadscan (optional).
MONAD_API_KEY=

# ── Frontend (baked into the Next.js build) ───────────────────────────────────
# Monad Testnet contracts (Chain ID 10143)
NEXT_PUBLIC_MONAD_NFT_CONTRACT=0x67841E9cCa5bfd49A9102245277d6EdD5bCE8453
NEXT_PUBLIC_MONAD_REWARD_CONTRACT=0xB59F9C7cdC9eF972c20ed9024cEEBe11820909FC
NEXT_PUBLIC_MONAD_CCOP_CONTRACT=0xB0207dD36D1441592aF6EC59dfC390B1f974615f
NEXT_PUBLIC_MONAD_CHAIN_ID=10143

# Local Hardhat contracts (populated after `docker compose run contracts npx hardhat run scripts/deploy-local.js`)
NEXT_PUBLIC_LOCAL_NFT_CONTRACT=
NEXT_PUBLIC_LOCAL_REWARD_CONTRACT=
NEXT_PUBLIC_LOCAL_CCOP_CONTRACT=

# Backend API reachable from the browser (use localhost for local dev)
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000
